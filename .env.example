# 多智能体协同作业平台 - 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改

# ==================== 基础配置 ====================
APP_NAME=多智能体协同作业平台
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/macp_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== RabbitMQ 配置 ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==================== 安全配置 ====================
# 生产环境务必修改为强随机密钥
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 加密配置 ====================
# 必须是 32 字节长度的密钥
ENCRYPTION_KEY=your-encryption-key-32-bytes-long!
TLS_VERSION=TLSv1.3
USE_CHINESE_CRYPTO=true

# ==================== 智能体配置 ====================
MAX_AGENTS=1000
AGENT_HEARTBEAT_INTERVAL=30
AGENT_TIMEOUT=300

# ==================== 任务调度配置 ====================
TASK_QUEUE_NAME=agent_tasks
MAX_TASK_RETRIES=3
TASK_RETRY_DELAY=60
# 调度算法：reinforcement_learning, weighted, round_robin
SCHEDULER_ALGORITHM=reinforcement_learning

# ==================== 监控配置 ====================
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== 限流配置 ====================
RATE_LIMIT_PER_SECOND=100
RATE_LIMIT_BURST=200
